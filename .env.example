# Local Database URL (used when USE_SUPABASE=false)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/your_database_name

# Supabase Configuration
USE_SUPABASE=false

# Vite public Supabase variables
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Development Environment
SUPABASE_URL_DEV=https://your-project-id.supabase.co
SUPABASE_ANON_KEY_DEV=your-dev-anon-key-here

# Supabase PostgreSQL connection strings (for migrations)
# Get these from Supabase Dashboard > Project Settings > Database > Connection string > URI format
SUPABASE_POSTGRES_URL_DEV=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Supabase Production Environment
SUPABASE_URL_PROD=https://your-project-id.supabase.co
SUPABASE_ANON_KEY_PROD=your-prod-anon-key-here
SUPABASE_POSTGRES_URL_PROD=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Environment (development or production)
NODE_ENV=development

# Server Configuration
PORT=5001

# CORS Configuration (comma-separated origins for production)
ALLOWED_ORIGINS=https://lefv.io,https://www.lefv.io

# Weather API Configuration (Ambient Weather)
AMBIENT_API_KEY=your-ambient-api-key-here
AMBIENT_APP_KEY=your-ambient-app-key-here
AMBIENT_MAC_ADDRESS=your-station-mac-address-here

# OpenWeatherMap API (for public weather fallback)
OPENWEATHER_API_KEY=your-openweather-api-key-here
OPENWEATHER_CITY=Paris
OPENWEATHER_COUNTRY=FR

# Logging
LOG_LEVEL=info

# Session Secret
SESSION_SECRET=your-session-secret-here-change-in-production